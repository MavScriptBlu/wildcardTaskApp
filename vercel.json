{
	"services": {
		"frontend": {
			"root": "frontend",
			"framework": "sveltekit-1"
		},
		"backend": {
			"root": "backend",
			"entrypoint": "app.main:app"
		}
	},
	"rewrites": [
		{
			"source": "/api(/.*)?",
			"destination": {
				"type": "service",
				"service": "backend"
			}
		},
		{
			"source": "/(.*)",
			"destination": {
				"type": "service",
				"service": "frontend"
			}
		}
	]
}
