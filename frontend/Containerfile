# ---- Stage 1: Build the application ----
FROM node:20-alpine AS build

WORKDIR /app

# this is baked into the app when it's built, so the browser knows
# where to send API requests. Override it with --build-arg if needed.
ARG VITE_API_URL=http://localhost:8000
ENV VITE_API_URL=$VITE_API_URL

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

# ---- Stage 2: Run the built app ----
# this keeps the final image small since it skips all the build tools
FROM node:20-alpine

WORKDIR /app

COPY --from=build /app/build ./build
COPY --from=build /app/package*.json ./
RUN npm install --omit=dev

EXPOSE 3000
CMD ["node", "build"]